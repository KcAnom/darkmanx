# darkman-x-pi — Pi-only secrets for this project
# Copy to darkman-x-pi.env and paste your key:
#   cp .pi/darkman-x-pi.env.example .pi/darkman-x-pi.env
# Get a key: https://fish.audio/app/api-keys/

FISH_API_KEY=paste_your_fish_api_key_here

# Optional overrides (defaults already match last commit):
# DARKMANX_VOICE_ID=552fdfe0e4f542c1bb381d1006c1ac9b
# DARKMANX_VOICE_MODEL=s2.1-pro-free
# DARKMANX_VOICE=off
# DARKMANX_VOICE_PLAY=1
# DARKMANX_DEFAULT_MODE=full
