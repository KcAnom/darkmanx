# Fish Audio — required for darkman-x spoken voice (S2.1-Pro)
# Get a key: https://fish.audio/app/api-keys/
# Copy this file to .env and paste your key (never commit .env).

FISH_API_KEY=paste_your_fish_api_key_here

# Optional overrides (defaults are already set for darkman-x):
# DARKMANX_VOICE_ID=552fdfe0e4f542c1bb381d1006c1ac9b
# DARKMANX_VOICE_MODEL=s2.1-pro
# DARKMANX_VOICE=off
# DARKMANX_VOICE_PLAY=1
