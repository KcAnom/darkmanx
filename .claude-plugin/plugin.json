{
  "name": "darkman-x",
  "version": "0.1.0",
  "description": "Make AI coding agents talk like Darkman X — short, hard, ~65% fewer output tokens. Code, commands, and errors stay byte-exact.",
  "author": {
    "name": "darkman-x",
    "url": "https://github.com/KcAnom/darkmanx"
  },
  "homepage": "https://github.com/KcAnom/darkmanx",
  "repository": "https://github.com/KcAnom/darkmanx",
  "license": "MIT",
  "keywords": [
    "agent-skill",
    "prompt-compression",
    "token-savings"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/darkman-x-activate.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/darkman-x-mode-tracker.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
