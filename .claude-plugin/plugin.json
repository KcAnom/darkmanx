{
  "name": "darkman-x",
  "version": "0.1.0",
  "description": "Make AI coding agents talk like Darkman X — short, hard, ~65% fewer output tokens. Code, commands, and errors stay byte-exact.",
  "author": {
    "name": "darkman-x"
  },
  "keywords": [
    "agent-skill",
    "prompt-compression"
  ],
  "skills": "./skills",
  "commands": "./commands",
  "agents": [
    "./agents"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/darkman-x-activate.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/darkman-x-mode-tracker.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
